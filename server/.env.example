# ADLM Website — server environment template
# Copy to `server/.env` and fill in REAL values. NEVER commit the real .env.
# `.env` and `.env.*` are gitignored (this `.env.example` is the only exception).
#
# CRITICAL (server refuses to boot without these — see validateEnv() in index.js)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/dbname
JWT_ACCESS_SECRET=replace-with-32+char-random-string
JWT_REFRESH_SECRET=replace-with-DIFFERENT-32+char-random-string

# Plugin license signing ------------------------------------------------------
# HS256 (legacy, symmetric — the shared secret is distributed to plugins, so
# anyone with it can forge tokens). Kept for plugins not yet on RS256.
JWT_LICENSE_SECRET=replace-with-strong-random-secret
# RS256 (preferred, asymmetric — private key never leaves the server; plugins
# verify via /.well-known/jwks.json). Flip the algo once QUIV+Civil ship
# RS256-aware builds.
ADLM_LICENSE_SIGNING_ALGO=HS256
# JWT_LICENSE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Payments (Paystack) ---------------------------------------------------------
PAYSTACK_SECRET_KEY=sk_test_or_live_xxx
# Frontend origin used for the Paystack callback_url (also used by admin emails)
PUBLIC_WEB_URL=https://www.adlmstudio.net

# Media / storage -------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=xxx
CLOUDINARY_API_KEY=xxx
CLOUDINARY_API_SECRET=xxx
# Cloudflare R2 / S3-compatible
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET=xxx
# BunnyCDN stream (video)
BUNNY_STREAM_API_KEY=xxx
BUNNY_STREAM_LIBRARY_ID=xxx

# Email -----------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=admin@adlmstudio.net
SMTP_PASS=gmail-app-password
RESEND_API_KEY=re_xxx

# Integrations ----------------------------------------------------------------
OPENAI_API_KEY=sk-xxx
NOTION_API_KEY=secret_xxx
NOTION_CRM_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ADLM AI Agent ("Ada") — conversational sales agent at /agent/chat -----------
# Master switch. When not "true" the widget shows a friendly offline fallback.
AGENT_ENABLED=true
# Provider: "anthropic" (recommended, default) or "openai". BOTH support the
# full agent (Buy/Sign-up buttons + lead capture) via native tool use.
AGENT_PROVIDER=anthropic
# Required when AGENT_PROVIDER=anthropic. Set your funded Claude key here.
# (OpenAI mode instead reuses OPENAI_API_KEY above.)
ANTHROPIC_API_KEY=sk-ant-xxx
# Model id. Default: claude-haiku-4-5-20251001 (fast + cheap — ideal for a
# public chat widget). Bump to a Sonnet id for richer answers at higher cost.
AGENT_MODEL=claude-haiku-4-5-20251001
# Optional: cap output tokens per model round-trip (default 700).
# AGENT_MAX_TOKENS=700
# WhatsApp number for the human-handoff button (digits only, country code first).
SUPPORT_WHATSAPP=2348106503524

# TimeMgt task database (separate Atlas cluster, read/write by web/mobile clients)
# The WPF desktop app writes directly to this cluster; Express exposes it via REST.
TIMEMGT_MONGO_URI=mongodb+srv://CHANGE_ME:CHANGE_ME@timemgt.lsbs0in.mongodb.net/?appName=TimeMgt
TIMEMGT_DB=TimeMgt
TIMEMGT_COLLECTION=LaborTasks

# Runtime ---------------------------------------------------------------------
NODE_ENV=production
PORT=4000
# Comma-separated allowed CORS origins (see index.js)
CORS_ORIGINS=https://www.adlmstudio.net,https://adlmstudio.net
# Set to "1"/"true" to serve the built client from this server
SERVE_CLIENT=false
# Expiry-notifier cron (defaults: enabled, 9am Africa/Lagos)
ENABLE_EXPIRY_CRON=true
EXPIRY_CRON=0 9 * * *
# Auto-renewal cron — charges saved Paystack cards (NGN) for entitlements with
# autoRenew=true expiring within RENEW_WINDOW_DAYS. Runs before the expiry
# notifier so renewed users don't get an "expiring soon" email the same day.
# Defaults: enabled, 8am Africa/Lagos, 3-day window.
ENABLE_RENEWAL_CRON=true
RENEWAL_CRON=0 8 * * *
RENEW_WINDOW_DAYS=3

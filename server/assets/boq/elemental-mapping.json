{
  "_meta": {
    "version": 1,
    "notes": "Phase-1 elemental BoQ structure ported from RevitPluginArch (BungalowBoqExporter.cs / MultiStoreyBoqExporter.cs). Multi-storey substructure uses Pad/Strip default; Raft and Pile variants are a future iteration. Lookups use case-insensitive AND-of-words matching against an item's description/takeoffLine/materialName/type. To extend, add elements/items here — no code changes required."
  },

  "domains": {
    "quiv": {
      "bungalow": {
        "title": "Bill of Quantities — Bungalow",
        "bills": [
          {
            "name": "Preliminaries",
            "elements": [
              {
                "heading": "BREAKDOWN OF PRELIMINARIES",
                "items": [
                  { "description": "Setting Out", "unit": "Item" },
                  { "description": "Progress Photographs and Reports", "unit": "Item" },
                  { "description": "Foreman / Management supervision", "unit": "Item" },
                  { "description": "Other staff", "unit": "Item" },
                  { "description": "Insurances", "unit": "Item" },
                  { "description": "Site accommodation", "unit": "Item" },
                  { "description": "Office accommodation", "unit": "Item" },
                  { "description": "Site security", "unit": "Item" },
                  { "description": "Temporary fences", "unit": "Item" },
                  { "description": "Telephone", "unit": "Item" },
                  { "description": "Administration", "unit": "Item" },
                  { "description": "Material tests / Samples", "unit": "Item" },
                  { "description": "Removal of debris", "unit": "Item" },
                  { "description": "Water for the Works", "unit": "Item" },
                  { "description": "Power for the Works", "unit": "Item" },
                  { "description": "Notice board", "unit": "Item" },
                  { "description": "Temporary power/ lights", "unit": "Item" },
                  { "description": "Safety/ Health & Welfare", "unit": "Item" },
                  { "description": "Storage", "unit": "Item" },
                  { "description": "Small Plant/ Tools", "unit": "Item" },
                  { "description": "Plant Equipment/ scaffolding", "unit": "Item" },
                  { "description": "Additional Items", "unit": "Item" }
                ]
              }
            ]
          },
          {
            "name": "Substructure",
            "elements": [
              {
                "heading": "EXCAVATION, FILLING, ETC OTHER THAN BULK",
                "items": [
                  { "description": "Trench Excavation", "unit": "m3", "lookups": [["strip", "footing", "excavation"]] },
                  { "description": "Surplus material from excavations and/or stock piles on site", "unit": "m3", "lookups": [["strip", "footing", "excavation"]] },
                  { "description": "Sides of trench and hole excavations exceeding 2m deep", "unit": "m2", "lookups": [["strip", "earthwork", "support"]] },
                  { "description": "Keeping excavations free of water", "unit": "Item", "fixedAmount": 300000 },
                  { "description": "Backfilling to trenches, holes, etc", "unit": "m3", "lookups": [["strip", "backfilling"], ["strip", "backfill"]] },
                  { "description": "Under surface beds", "unit": "m3", "lookups": [["oversite", "hardcore", "filling"]] },
                  { "description": "G2 Sub base layer under surface beds average thickness exceeding 2m", "unit": "m3", "lookups": [["oversite", "laterite", "filling"]] }
                ]
              },
              {
                "heading": "COMPACTION",
                "items": [
                  { "description": "Compaction of ground surface under floors etc including scarifying", "unit": "m2", "lookups": [["strip", "leveling", "compacting"], ["strip", "leveling"]] }
                ]
              },
              {
                "heading": "SOIL POISONING",
                "items": [
                  { "description": "Apply soil treatment to under floors", "unit": "m2", "lookups": [["strip", "surface", "treatment"]] }
                ]
              },
              {
                "heading": "UNREINFORCED CONCRETE CAST AGAINST EXCAVATED SURFACES",
                "items": [
                  { "description": "Surface blinding against earth and unblinded sand", "unit": "m3", "lookups": [["oversite", "blinding"], ["strip", "blinding"]], "lookupCombine": "sum" }
                ]
              },
              {
                "heading": "REINFORCED CONCRETE",
                "items": [
                  { "description": "Footing", "unit": "m3", "lookups": [["strip", "concrete", "footing"], ["strip", "concrete", "in", "footing"]] },
                  { "description": "Surface slabs and steps cast in panels on waterproofing", "unit": "m3", "lookups": [["oversite", "concrete"]] }
                ]
              },
              {
                "heading": "FORMWORK",
                "items": [
                  { "description": "Edges, risers and ends not exceeding 300mm high or wide", "unit": "m", "lookups": [["oversite", "formwork", "edges"], ["oversite", "formwork", "to", "edges"]] }
                ]
              },
              {
                "heading": "REINFORCEMENT",
                "items": [
                  { "description": "BRC Wire Mesh", "unit": "m2", "lookups": [["oversite", "brc", "mesh"], ["oversite", "brc"]] }
                ]
              },
              {
                "heading": "DAMP-PROOFING",
                "items": [
                  { "description": "DPM to under floor slab", "unit": "m2", "lookups": [["oversite", "dpm"]] }
                ]
              },
              {
                "heading": "BLOCKWORK IN FOUNDATION",
                "items": [
                  { "description": "Sandcrete hollow blockwork in foundation", "unit": "m2", "lookups": [["strip", "blockwork"]] },
                  { "description": "Damp proof course", "unit": "m", "lookups": [["strip", "damp", "proof"], ["strip", "dpc"]] }
                ]
              }
            ]
          },
          {
            "name": "Superstructure",
            "elements": [
              {
                "heading": "WALLS — REINFORCED CONCRETE",
                "items": [
                  { "description": "Lintels", "unit": "m3", "lookups": [["blockwork", "lintel", "concrete"]], "defaultRate": 45000 }
                ]
              },
              {
                "heading": "WALLS — FORMWORK",
                "items": [
                  { "description": "Lintel formwork", "unit": "m2", "lookups": [["blockwork", "lintel", "formwork"]], "defaultRate": 4850 }
                ]
              },
              {
                "heading": "WALLS — REINFORCEMENT",
                "items": [
                  { "description": "10-12mm Diameter bars in lintel", "unit": "t", "lookups": [["blockwork", "lintel", "reinforcement"]], "qtyDivisor": 1000, "defaultRate": 575000 }
                ]
              },
              {
                "heading": "WALLS — BLOCKWORK",
                "items": [
                  { "description": "Sandcrete hollow blockwork in wall, generally internal and external", "unit": "m2", "lookups": [["blockwork", "wall", "area"]], "defaultRate": 8350 }
                ]
              },
              {
                "heading": "ROOF COVERING AND MEMBERS",
                "items": [
                  { "description": "Roof covering", "unit": "m2", "lookups": [["roof", "area"]], "defaultRate": 6375 },
                  { "description": "50 x 100mm Hardwood Strut and Ties", "unit": "m", "lookups": [["roof", "structs"], ["roof", "strut"]], "defaultRate": 650 },
                  { "description": "50 x 150mm Hardwood King Post", "unit": "m", "lookups": [["roof", "king", "post"], ["roof", "kingpost"]], "defaultRate": 850 },
                  { "description": "50 x 150mm Hardwood Wall Plate", "unit": "m", "lookups": [["roof", "wall", "plate"], ["roof", "wallplate"]], "defaultRate": 850 },
                  { "description": "50 x 50mm Hardwood Ceiling Noggins", "unit": "m", "lookups": [["ceiling", "nogging"]], "defaultRate": 362 },
                  { "description": "50 x 75mm Hardwood Purlins", "unit": "m", "lookups": [["roof", "purlin"]], "defaultRate": 447 },
                  { "description": "50 x 150mm Hardwood Rafters", "unit": "m", "lookups": [["roof", "rafter"]], "defaultRate": 850 }
                ]
              },
              {
                "heading": "WINDOWS AND DOORS",
                "items": [
                  { "description": "Aluminium casement windows complete with fly screen", "unit": "No", "lookups": [["window"]], "defaultRate": 55000 },
                  { "description": "Wooden panel doors complete with frame and ironmongery", "unit": "No", "lookups": [["door"]], "defaultRate": 95000 }
                ]
              },
              {
                "heading": "FLOOR, WALL AND CEILING FINISHES",
                "items": [
                  { "description": "Floor finishes (tiles/screed)", "unit": "m2", "lookups": [["finishes", "tile"], ["finishes", "total", "tile"]], "defaultRate": 5500 },
                  { "description": "Wall rendering / plastering", "unit": "m2", "lookups": [["blockwork", "wall", "rendering"]], "defaultRate": 2500 },
                  { "description": "Painting (emulsion / texcote)", "unit": "m2", "lookups": [["blockwork", "wall", "rendering"]], "defaultRate": 1200 },
                  { "description": "Ceiling finishes (POP / board)", "unit": "m2", "lookups": [["ceiling", "area"]], "defaultRate": 4500 }
                ]
              }
            ]
          }
        ]
      },

      "multistorey": {
        "title": "Bill of Quantities — Multi-Storey",
        "bills": [
          {

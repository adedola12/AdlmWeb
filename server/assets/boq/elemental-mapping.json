              },
              {
                "heading": "BLOCKWORK & DPC",
                "items": [
                  { "description": "Blockwork in foundation", "unit": "m2", "lookups": [["pad", "blockwork"], ["strip", "blockwork"]] },
                  { "description": "Damp Proof Course (DPC)", "unit": "m", "lookups": [["pad", "dpc"], ["strip", "dpc"]] }
                ]
              }
            ]
          },
          {
            "name": "Frame",
            "elements": [
              {
                "heading": "REINFORCED CONCRETE — E10",
                "items": [
                  { "description": "Columns", "unit": "m3", "lookups": [["column", "concrete"]] },
                  { "description": "Beams", "unit": "m3", "lookups": [["beam", "concrete"]] },
                  { "description": "Suspended slabs", "unit": "m3", "lookups": [["slab", "concrete"]] }
                ]
              },
              {
                "heading": "FORMWORK — E20",
                "items": [
                  { "description": "Column formwork", "unit": "m2", "lookups": [["column", "formwork"]] },
                  { "description": "Beam formwork", "unit": "m2", "lookups": [["beam", "formwork"]] },
                  { "description": "Slab soffit formwork", "unit": "m2", "lookups": [["slab", "formwork"]] }
                ]
              },
              {
                "heading": "REINFORCEMENT — E30",
                "items": [
                  { "description": "10-25mm Diameter bars in columns", "unit": "t", "lookups": [["column", "reinforcement"]], "qtyDivisor": 1000 },
                  { "description": "10-25mm Diameter bars in beams", "unit": "t", "lookups": [["beam", "reinforcement"]], "qtyDivisor": 1000 },
                  { "description": "10-16mm Diameter bars in slabs", "unit": "t", "lookups": [["slab", "reinforcement"]], "qtyDivisor": 1000 }

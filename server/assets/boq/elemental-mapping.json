                  { "description": "Excavated area", "unit": "m2", "lookups": [["pad", "excavation", "area"], ["strip", "excavation", "area"]] },
                  { "description": "Depositing on site", "unit": "m3", "lookups": [["pad", "depositing"], ["strip", "depositing"]] },

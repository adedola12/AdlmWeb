                  { "description": "Reinforcement in column base (Pad foundation)", "unit": "t", "lookups": [["pad", "reinforcement"]], "qtyDivisor": 1000 }
                ]
              },
              {
                "heading": "OTHER REINFORCEMENT & DPM",

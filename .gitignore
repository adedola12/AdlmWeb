# Environment files — never commit secrets
.env
.env.*
!.env.example

# Dependencies
node_modules/

# Build output
dist/
build/

# Credential files
*.pem
*.key
*.pfx
*.p12
secrets.json

# Local secret overrides for ops scripts (never commit real secrets)
scripts/*.secrets.ps1

# Stray error dumps (untrack existing ones with:
#   git rm --cached client/err*.txt client/receipt-err.txt )
err*.txt
*-err.txt

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Test/temp
coverage/
tmp/
temp/

# Claude Code (local agent state & worktrees)
.claude/
